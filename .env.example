# Copy this file to ".env" and fill in your real keys.
# Never commit the real ".env" file to GitHub — it's already in .gitignore.

GITHUB_API_KEY=your_github_models_token_here
GROQ_API_KEY=your_groq_api_key_here

# Any random long string works here — used to sign Flask session cookies.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-string

# Optional — used by app.py in production
FLASK_ENV=production
PORT=5000
